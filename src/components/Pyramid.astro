---
// Decorative ASCII pyramid with accessible text alternative.
// Layers top→bottom: Equanimity (outcome), Awareness (practice), Sovereignty (foundation).
const layers = [
  {
    name: "Equanimity",
    role: "outcome",
    principles: ["Strategic Friction", "Fade-by-Design", "Downstream Allocation"],
  },
  {
    name: "Awareness",
    role: "practice",
    principles: ["Peripheral Presence", "Attentional Granularity", "Bounded Experiences"],
  },
  {
    name: "Sovereignty",
    role: "foundation",
    principles: ["Local-First Ownership", "Holistic Control", "Modification Rights"],
  },
];
---
<figure class="pyramid">
  <pre class="pyramid__ascii" aria-hidden="true">
              /\
             /  \
            / EQ \
           /------\
          /        \
         /    AW    \
        /------------\
       /              \
      /       SO       \
     /__________________\
  </pre>

  <ol class="pyramid__layers" aria-label="Three layers of the equanimitech framework, top to bottom">
    {layers.map((l) => (
      <li class="layer">
        <p class="layer__name">{l.name} <span class="layer__role">— {l.role}</span></p>
        <ul class="layer__principles" aria-label={`${l.name} principles`}>
          {l.principles.map((p) => <li>{p}</li>)}
        </ul>
      </li>
    ))}
  </ol>
</figure>
