---
interface ProjectLink {
  label: string;
  href: string;
}
interface Props {
  name: string;
  tagline: string;
  body: string;
  links: ProjectLink[];
}
const { name, tagline, body, links } = Astro.props;
---
<article class="project">
  <p class="project__name">{name}</p>
  <p class="project__tag">{tagline}</p>
  <p class="project__body">{body}</p>
  <p class="project__links">
    {links.map((l, i) => (
      <>
        {i > 0 && <span aria-hidden="true">·</span>}
        <a href={l.href}>{l.label}</a>
      </>
    ))}
  </p>
</article>
